{
  "info": {
    "name": "BarberHub API",
    "description": "Collection para teste da API BarberHub",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "User",
      "item": [
        {
          "name": "List all users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/v1/user"
          }
        },
        {
          "name": "Create user",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/v1/user",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"joao@email.com\",\n  \"telephone\": \"11999999999\",\n  \"password\": \"12345678\"\n}"
            }
          }
        },
        {
          "name": "Update user",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/v1/user/1",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"joao.atualizado@email.com\",\n  \"telephone\": \"11988888888\"\n}"
            }
          }
        },
        {
          "name": "Change password",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/v1/user/1/change-password",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"12345678\",\n  \"newPassword\": \"87654321\",\n  \"confirmPassword\": \"87654321\"\n}"
            }
          }
        },
        {
          "name": "Disable user",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/v1/user/1/disable"
          }
        }
      ]
    },
    {
      "name": "Barber",
      "item": [
        {
          "name": "List all barbers",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/v1/barber"
          }
        },
        {
          "name": "Find barber by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/v1/barber/1"
          }
        },
        {
          "name": "Find barbers by specialty",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/v1/barber/specialty/CORTE"
          }
        },
        {
          "name": "Create barber",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/v1/barber/create",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"João Silva\",\n  \"userId\": 1,\n  \"specialty\": [\"CORTE\", \"BARBA\"]\n}"
            }
          }
        },
        {
          "name": "Update barber",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/v1/barber/1",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"specialty\": [\"CORTE\", \"BARBA\", \"SOBRANCELHA\"],\n  \"active\": true\n}"
            }
          }
        },
        {
          "name": "Disable barber",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/v1/barber/1/disable"
          }
        }
      ]
    },
    {
      "name": "Service Item",
      "item": [
        {
          "name": "List all service items",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/v1/serviceitem"
          }
        },
        {
          "name": "Find service item by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/v1/serviceitem/1"
          }
        },
        {
          "name": "Create service item",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/v1/serviceitem/create",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"CORTE\",\n  \"price\": 35.00,\n  \"durationInMinutes\": 30\n}"
            }
          }
        },
        {
          "name": "Update service item",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/v1/serviceitem/1",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 40.00,\n  \"durationInMinutes\": 45\n}"
            }
          }
        },
        {
          "name": "Disable service item",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/v1/serviceitem/1/disable"
          }
        }
      ]
    },
    {
      "name": "Appointment",
      "item": [
        {
          "name": "List all appointments",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/v1/appointment"
          }
        },
        {
          "name": "Find appointments by barber",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/v1/appointment/barber/1"
          }
        },
        {
          "name": "Find appointments by user",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/v1/appointment/user/1"
          }
        },
        {
          "name": "Create appointment",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/v1/appointment/create",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 1,\n  \"barberId\": 1,\n  \"serviceItemId\": 1,\n  \"availableDate\": \"2026-06-01\",\n  \"availableTime\": \"09:00:00\"\n}"
            }
          }
        },
        {
          "name": "Cancel appointment",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/v1/appointment/1/cancel"
          }
        },
        {
          "name": "Complete appointment",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/v1/appointment/1/complete"
          }
        }
      ]
    },
    {
      "name": "Review",
      "item": [
        {
          "name": "Find reviews by barber",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/v1/review/barber/1"
          }
        },
        {
          "name": "Create review",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/v1/review/create",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 1,\n  \"barberId\": 1,\n  \"rating\": 5.0,\n  \"comment\": \"Excelente atendimento!\"\n}"
            }
          }
        },
        {
          "name": "Delete review",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/v1/review/1"
          }
        }
      ]
    }
  ]
}